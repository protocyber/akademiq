# =============================================================================
# AkademiQ — Parent repo orchestrator environment
# =============================================================================
# Copy this file to `.env`. Variables here drive the orchestrator (mprocs,
# tmux, parallel make). Per-app variables (Postgres ports, Web port, etc.)
# live in `apps/backend/.env` and `apps/web/.env`.
#
# `.env` is gitignored everywhere.
# =============================================================================

# Submodule mount paths (rarely changed).
BACKEND_DIR=apps/backend
WEB_DIR=apps/web
WEB_ADMIN_DIR=apps/web-admin

# Path (relative to repo root) of the mprocs config consumed by `make dev`.
MPROCS_CONFIG=mprocs.yaml

# tmux session name used by `make dev-tmux`.
TMUX_SESSION=akademiq
